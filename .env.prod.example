# ── Production .env ────────────────────────────────────────────────────────────
# Copy to .env on the server, fill in real values, chmod 600 .env

APP_NAME=Leo RAG System
DEBUG=false
API_PREFIX=/api/v1

# ── Security ───────────────────────────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ───────────────────────────────────────────────────────────────────
# Overridden by docker-compose.prod.yml to use service name; keep this as fallback
DATABASE_URL=postgresql+psycopg://leo:CHANGE_DB_PASSWORD@postgres:5432/leo_rag
POSTGRES_USER=leo
POSTGRES_PASSWORD=CHANGE_DB_PASSWORD
POSTGRES_DB=leo_rag

# ── MinIO ──────────────────────────────────────────────────────────────────────
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=CHANGE_MINIO_USER
STORAGE_SECRET_KEY=CHANGE_MINIO_PASSWORD   # min 12 chars
STORAGE_BUCKET=leo-documents
STORAGE_USE_SSL=false
MINIO_ROOT_USER=CHANGE_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_MINIO_PASSWORD

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=leo_chunks
QDRANT_VECTOR_SIZE=1536

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2048

# ── RAG ────────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=20
RERANKER_TOP_N=5

# ── Upload ─────────────────────────────────────────────────────────────────────
ALLOWED_EXTENSIONS=["pdf","docx","txt"]
MAX_UPLOAD_SIZE_MB=50

# ── CORS — set to your actual frontend domain ──────────────────────────────────
CORS_ORIGINS=["https://your-domain.com"]

# ── Reranker ───────────────────────────────────────────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
