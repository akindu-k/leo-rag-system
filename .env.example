# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Leo RAG System
DEBUG=false
API_PREFIX=/api/v1

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://leo:leo_password@localhost:5432/leo_rag

# ─── MinIO / S3 ───────────────────────────────────────────────────────────────
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin123
STORAGE_BUCKET=leo-documents
STORAGE_USE_SSL=false
# For AWS S3, set STORAGE_ENDPOINT to s3.amazonaws.com and STORAGE_USE_SSL=true

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=leo_chunks
QDRANT_VECTOR_SIZE=1536

# ─── OpenAI (embeddings) ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# ─── Anthropic (answer LLM) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5-20251001

# ─── RAG settings ─────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=20
RERANKER_TOP_N=5

# ─── Upload settings ──────────────────────────────────────────────────────────
ALLOWED_EXTENSIONS=["pdf","docx","txt"]
MAX_UPLOAD_SIZE_MB=50

# ─── Reranker model ───────────────────────────────────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins. Use * only in development.
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
